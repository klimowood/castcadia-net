{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{"name": "next"}],
    "paths": {
      "@/*": ["./app/src/*"]
    }
  },
  "include": [
    "app/next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/.next/types/**/*.ts",
    "app/.next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "app/src/scripts"]
}
